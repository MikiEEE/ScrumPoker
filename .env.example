# Optional bind host for the shared SmallOS listener.
# Leave this as 0.0.0.0 to allow other devices on your LAN to reach the app.
HOST=0.0.0.0

# Optional TCP port for the shared listener that serves the landing page,
# setup flow, premium room, and all ephemeral rooms.
# Change this if 8082 is already in use on your machine.
PORT=8082

# Dedicated admin passphrase for the premium /legalease room.
# If this is blank, the app falls back to ADMIN_PASSPHRASE for /legalease only.
LEGALEASE_ADMIN_PASSPHRASE=password

# Legacy fallback admin passphrase. This is only used for /legalease when
# LEGALEASE_ADMIN_PASSPHRASE is not set.
ADMIN_PASSPHRASE=Spassword

# Super-user passphrase that can unlock admin in any room, including ephemeral rooms.
SUPER_USER_PASSPHRASE=super-secret

# Global cap for all live websocket transports across every active room.
# The default is 320, which leaves headroom above the joined-participant limits.
MAX_CONNECTIONS=320

# Optional comma-separated list of allowed browser origins for WebSocket upgrades.
# Leave blank to allow any origin, or set it to your public app URLs for tighter access control.
ALLOWED_ORIGINS=https://your-poker.example.com
